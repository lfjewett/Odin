{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "acp/schemas/messages.json",
  "title": "ACP Message Envelope",
  "oneOf": [
    { "$ref": "#/$defs/subscribe" },
    { "$ref": "#/$defs/unsubscribe" },
    { "$ref": "#/$defs/reconfigure" },
    { "$ref": "#/$defs/data" },
    { "$ref": "#/$defs/heartbeat" },
    { "$ref": "#/$defs/error" },
    { "$ref": "#/$defs/history_push" },
    { "$ref": "#/$defs/tick_update" },
    { "$ref": "#/$defs/candle_closed" },
    { "$ref": "#/$defs/candle_correction" },
    { "$ref": "#/$defs/resync_response" },
    { "$ref": "#/$defs/resync_request" },
    { "$ref": "#/$defs/history_response" },
    { "$ref": "#/$defs/overlay_update" },
    { "$ref": "#/$defs/overlay_marker" }
  ],
  "$defs": {
    "schema_name": {
      "type": "string",
      "enum": ["ohlc", "line", "event", "band", "area", "histogram", "forecast"]
    },
    "base": {
      "type": "object",
      "required": ["type", "spec_version", "session_id", "subscription_id", "agent_id"],
      "properties": {
        "type": { "type": "string" },
        "spec_version": { "type": "string", "enum": ["ACP-0.4.0", "ACP-0.4.1"] },
        "session_id": { "type": "string", "minLength": 1 },
        "subscription_id": { "type": "string", "minLength": 1 },
        "agent_id": { "type": "string", "minLength": 1 }
      }
    },
    "chunk_fields": {
      "type": "object",
      "properties": {
        "chunk_index": { "type": "integer", "minimum": 0 },
        "total_chunks": { "type": "integer", "minimum": 1 },
        "is_final_chunk": { "type": "boolean" }
      }
    },
    "subscribe": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "spec_version", "session_id", "subscription_id", "agent_id", "symbol", "interval", "params"],
          "properties": {
            "type": { "const": "subscribe" },
            "symbol": { "type": "string", "minLength": 1 },
            "interval": { "type": "string", "enum": ["1m", "2m", "3m", "4m", "5m", "10m", "15m", "20m", "30m", "1h", "2h", "4h", "8h", "12h", "1d", "2d", "1w", "1M"] },
            "indicator_id": { "type": "string", "minLength": 1 },
            "params": { "type": "object" }
          }
        }
      ]
    },
    "unsubscribe": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "spec_version", "session_id", "subscription_id", "agent_id"],
          "properties": {
            "type": { "const": "unsubscribe" }
          }
        }
      ]
    },
    "reconfigure": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "spec_version", "session_id", "subscription_id", "agent_id", "symbol", "interval", "new_params"],
          "properties": {
            "type": { "const": "reconfigure" },
            "symbol": { "type": "string", "minLength": 1 },
            "interval": { "type": "string", "enum": ["1m", "2m", "3m", "4m", "5m", "10m", "15m", "20m", "30m", "1h", "2h", "4h", "8h", "12h", "1d", "2d", "1w", "1M"] },
            "indicator_id": { "type": "string", "minLength": 1 },
            "new_params": { "type": "object" }
          }
        }
      ]
    },
    "data": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "spec_version", "session_id", "subscription_id", "agent_id", "schema", "record"],
          "properties": {
            "type": { "const": "data" },
            "schema": { "$ref": "#/$defs/schema_name" },
            "record": { "type": "object" }
          }
        }
      ]
    },
    "heartbeat": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "spec_version", "session_id", "subscription_id", "agent_id", "status", "uptime_s", "last_event_ts"],
          "properties": {
            "type": { "const": "heartbeat" },
            "status": { "type": "string", "enum": ["ok", "degraded", "error"] },
            "uptime_s": { "type": "integer", "minimum": 0 },
            "last_event_ts": { "type": "string", "format": "date-time" }
          }
        }
      ]
    },
    "error": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "spec_version", "session_id", "subscription_id", "agent_id", "code", "message", "retryable"],
          "properties": {
            "type": { "const": "error" },
            "code": {
              "type": "string",
              "enum": [
                "INVALID_REQUEST",
                "INVALID_SYMBOL",
                "INVALID_INTERVAL",
                "INVALID_PARAMS",
                "UNSUPPORTED_OPERATION",
                "SUBSCRIPTION_NOT_FOUND",
                "SESSION_NOT_FOUND",
                "AGENT_OVERLOADED",
                "BACKFILL_TIMEOUT",
                "RESYNC_FAILED",
                "INTERNAL_ERROR",
                "PAYLOAD_TOO_LARGE",
                "CHUNK_SEQUENCE_ERROR"
              ]
            },
            "message": { "type": "string", "minLength": 1 },
            "retryable": { "type": "boolean" },
            "details": { "type": "object" }
          }
        }
      ]
    },
    "history_push": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        { "$ref": "#/$defs/chunk_fields" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "spec_version", "session_id", "subscription_id", "agent_id", "symbol", "interval", "candles", "count"],
          "properties": {
            "type": { "const": "history_push" },
            "symbol": { "type": "string", "minLength": 1 },
            "interval": { "type": "string", "enum": ["1m", "2m", "3m", "4m", "5m", "10m", "15m", "20m", "30m", "1h", "2h", "4h", "8h", "12h", "1d", "2d", "1w", "1M"] },
            "candles": {
              "type": "array",
              "items": { "$ref": "ohlc.json" }
            },
            "count": { "type": "integer", "minimum": 0 },
            "chunk_index": { "type": "integer", "minimum": 0 },
            "total_chunks": { "type": "integer", "minimum": 1 },
            "is_final_chunk": { "type": "boolean" }
          }
        }
      ]
    },
    "tick_update": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "spec_version", "session_id", "subscription_id", "agent_id", "seq", "candle"],
          "properties": {
            "type": { "const": "tick_update" },
            "seq": { "type": "integer", "minimum": 0 },
            "candle": { "$ref": "ohlc.json" }
          }
        }
      ]
    },
    "candle_closed": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "spec_version", "session_id", "subscription_id", "agent_id", "seq", "candle"],
          "properties": {
            "type": { "const": "candle_closed" },
            "seq": { "type": "integer", "minimum": 0 },
            "candle": { "$ref": "ohlc.json" }
          }
        }
      ]
    },
    "candle_correction": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "spec_version", "session_id", "subscription_id", "agent_id", "seq", "candle", "reason"],
          "properties": {
            "type": { "const": "candle_correction" },
            "seq": { "type": "integer", "minimum": 0 },
            "candle": { "$ref": "ohlc.json" },
            "reason": { "type": "string", "minLength": 1 }
          }
        }
      ]
    },
    "resync_response": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "spec_version", "session_id", "subscription_id", "agent_id", "last_seq_received", "messages"],
          "properties": {
            "type": { "const": "resync_response" },
            "last_seq_received": { "type": "integer", "minimum": 0 },
            "messages": {
              "type": "array",
              "items": { "type": "object" }
            }
          }
        }
      ]
    },
    "resync_request": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "spec_version", "session_id", "subscription_id", "agent_id", "last_seq_received"],
          "properties": {
            "type": { "const": "resync_request" },
            "last_seq_received": { "type": "integer", "minimum": 0 }
          }
        }
      ]
    },
    "history_response": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        { "$ref": "#/$defs/chunk_fields" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "spec_version", "session_id", "subscription_id", "agent_id", "schema", "overlays"],
          "properties": {
            "type": { "const": "history_response" },
            "schema": {
              "type": "string",
              "enum": ["line", "event", "band", "area", "histogram", "forecast"]
            },
            "overlays": {
              "type": "array",
              "items": { "type": "object" }
            },
            "metadata": { "type": "object" },
            "chunk_index": { "type": "integer", "minimum": 0 },
            "total_chunks": { "type": "integer", "minimum": 1 },
            "is_final_chunk": { "type": "boolean" }
          }
        }
      ]
    },
    "overlay_update": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "spec_version", "session_id", "subscription_id", "agent_id", "schema", "record"],
          "properties": {
            "type": { "const": "overlay_update" },
            "schema": {
              "type": "string",
              "enum": ["line", "event", "band", "area", "histogram", "forecast"]
            },
            "record": { "type": "object" }
          }
        }
      ]
    },
    "overlay_marker": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "spec_version", "session_id", "subscription_id", "agent_id", "schema", "record"],
          "properties": {
            "type": { "const": "overlay_marker" },
            "schema": { "const": "event" },
            "record": { "type": "object" }
          }
        }
      ]
    }
  }
}
