{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "acp/schemas/area.json",
  "title": "ACP Area Record (Shaded Region)",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "ts", "output_id", "upper", "lower"],
  "properties": {
    "id": { 
      "type": "string", 
      "minLength": 1,
      "description": "Unique record identifier"
    },
    "seq": { 
      "type": "integer", 
      "minimum": 0,
      "description": "Sequence number for message ordering"
    },
    "ts": { 
      "type": "string", 
      "format": "date-time",
      "description": "ISO-8601 timestamp"
    },
    "output_id": {
      "type": "string",
      "minLength": 1,
      "description": "Stable output identifier matching indicator metadata outputs[].output_id"
    },
    "upper": { 
      "type": "number",
      "description": "Upper boundary value (e.g., fast MA)"
    },
    "lower": { 
      "type": "number",
      "description": "Lower boundary value (e.g., slow MA)"
    },
    "metadata": {
      "type": "object",
      "description": "Agent-specific extension data. Includes optional area rendering hints under metadata.render plus optional hidden strategy fields.",
      "properties": {
        "render": {
          "type": "object",
          "description": "Optional rendering hints for area fill. UI MAY ignore unsupported options.",
          "properties": {
            "primary_color": {
              "type": "string",
              "description": "Color used when top is over bottom (e.g., bullish state). Accepts CSS color string."
            },
            "secondary_color": {
              "type": "string",
              "description": "Color used when inverted. Can be empty string to disable inverted fill emphasis."
            },
            "opacity": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Opacity multiplier where 0 is transparent and 1 is opaque."
            },
            "transparency": {
              "type": "number",
              "minimum": 0,
              "maximum": 100,
              "description": "Transparency percentage where 0 is opaque and 100 is fully transparent."
            },
            "gradient": {
              "type": "object",
              "description": "Optional gradient definition for area fill.",
              "properties": {
                "enabled": { "type": "boolean" },
                "direction": {
                  "type": "string",
                  "enum": ["vertical", "horizontal"],
                  "description": "Gradient direction across the filled area."
                },
                "start_color": {
                  "type": "string",
                  "description": "Start color for gradient interpolation."
                },
                "end_color": {
                  "type": "string",
                  "description": "End color for gradient interpolation."
                }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  }
}
