{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "acp/schemas/session.json",
  "title": "ACP Session Lifecycle Messages",
  "oneOf": [
    { "$ref": "#/$defs/create_session" },
    { "$ref": "#/$defs/session_created" },
    { "$ref": "#/$defs/session_ready" },
    { "$ref": "#/$defs/close_session" }
  ],
  "$defs": {
    "interval": {
      "type": "string",
      "enum": ["1m", "5m", "15m", "30m", "1h", "4h", "1d"]
    },
    "create_session": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "spec_version", "symbol", "interval", "agent_ids"],
      "properties": {
        "type": { "const": "create_session" },
        "spec_version": { "type": "string", "const": "ACP-0.2.0" },
        "symbol": { "type": "string", "minLength": 1 },
        "interval": { "$ref": "#/$defs/interval" },
        "timeframe_days": { "type": "integer", "minimum": 1 },
        "agent_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        }
      }
    },
    "session_created": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "spec_version", "session_id", "timestamp"],
      "properties": {
        "type": { "const": "session_created" },
        "spec_version": { "type": "string", "const": "ACP-0.2.0" },
        "session_id": { "type": "string", "minLength": 1 },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "session_ready": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "spec_version", "session_id", "timestamp"],
      "properties": {
        "type": { "const": "session_ready" },
        "spec_version": { "type": "string", "const": "ACP-0.2.0" },
        "session_id": { "type": "string", "minLength": 1 },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "close_session": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "spec_version", "session_id"],
      "properties": {
        "type": { "const": "close_session" },
        "spec_version": { "type": "string", "const": "ACP-0.2.0" },
        "session_id": { "type": "string", "minLength": 1 }
      }
    }
  }
}
