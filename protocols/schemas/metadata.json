{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/odin/acp/schemas/metadata.json",
  "title": "ACP Agent Metadata Response",
  "description": "Schema for agent metadata endpoint response, providing capability discovery and typed output contracts",
  "type": "object",
  "required": [
    "spec_version",
    "agent_id",
    "agent_name",
    "agent_version",
    "description",
    "agent_type",
    "config_schema",
    "outputs",
    "transport_limits"
  ],
  "properties": {
    "spec_version": {
      "type": "string",
      "description": "ACP protocol version",
      "pattern": "^ACP-[0-9]+\\.[0-9]+\\.[0-9]+$",
      "examples": ["ACP-0.4.0"]
    },
    "agent_id": {
      "type": "string",
      "description": "Unique identifier for this agent type",
      "pattern": "^[a-z0-9_]+$",
      "examples": ["sma_20", "vwap", "rsi_14"]
    },
    "agent_name": {
      "type": "string",
      "description": "Human-readable agent name",
      "minLength": 1,
      "examples": ["Simple Moving Average", "VWAP Overlay"]
    },
    "agent_version": {
      "type": "string",
      "description": "Agent implementation version",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "examples": ["1.0.0", "2.1.3"]
    },
    "description": {
      "type": "string",
      "description": "Brief description of agent functionality",
      "minLength": 1
    },
    "agent_type": {
      "type": "string",
      "description": "Agent role in ACP session flow",
      "enum": ["price", "indicator", "event"]
    },
    "data_dependency": {
      "description": "Primary input dependency for this agent",
      "oneOf": [
        {
          "type": "string",
          "enum": ["ohlc", "event", "none"]
        },
        {
          "type": "null"
        }
      ]
    },
    "config_schema": {
      "type": "object",
      "description": "Configuration parameters the agent requires",
      "additionalProperties": {
        "type": "object",
        "required": ["type", "description", "required"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["string", "integer", "number", "boolean"],
            "description": "Parameter data type"
          },
          "description": {
            "type": "string",
            "description": "Human-readable parameter explanation"
          },
          "required": {
            "type": "boolean",
            "description": "Whether the parameter is mandatory"
          },
          "default": {
            "description": "Default value if not provided"
          },
          "min": {
            "type": "number",
            "description": "Minimum value (for integer/number types)"
          },
          "max": {
            "type": "number",
            "description": "Maximum value (for integer/number types)"
          },
          "pattern": {
            "type": "string",
            "description": "Regex pattern validation (for string type)"
          },
          "enum": {
            "type": "array",
            "description": "Allowed values (for string type)",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "outputs": {
      "type": "array",
      "description": "Typed output descriptors emitted by this agent",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["output_id", "schema", "label", "is_primary"],
        "properties": {
          "output_id": {
            "type": "string",
            "description": "Stable output identifier for routing and UI mapping",
            "minLength": 1
          },
          "schema": {
            "type": "string",
            "description": "Output record schema",
            "enum": ["ohlc", "line", "event", "band", "histogram", "forecast"]
          },
          "label": {
            "type": "string",
            "description": "Human readable output label",
            "minLength": 1
          },
          "is_primary": {
            "type": "boolean",
            "description": "Primary output marker"
          },
          "description": {
            "type": "string",
            "description": "Optional output description"
          }
        },
        "additionalProperties": false
      }
    },
    "transport_limits": {
      "type": "object",
      "description": "Transport and chunking limits for ACP v0.4.0",
      "required": [
        "max_records_per_chunk",
        "max_websocket_message_bytes"
      ],
      "properties": {
        "max_records_per_chunk": {
          "type": "integer",
          "minimum": 1000,
          "maximum": 10000,
          "examples": [5000]
        },
        "max_websocket_message_bytes": {
          "type": "integer",
          "minimum": 1048576,
          "examples": [10485760]
        },
        "chunk_timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "examples": [30]
        }
      },
      "additionalProperties": false
    },
    "indicators": {
      "type": "array",
      "description": "Discoverable indicator catalog for indicator agents",
      "items": {
        "type": "object",
        "required": ["indicator_id", "name", "description", "params_schema", "outputs"],
        "properties": {
          "indicator_id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "params_schema": {
            "type": "object",
            "description": "Parameter schema specific to this indicator",
            "additionalProperties": {
              "type": "object",
              "required": ["type", "description", "required"],
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["string", "integer", "number", "boolean"]
                },
                "description": {
                  "type": "string"
                },
                "required": {
                  "type": "boolean"
                },
                "default": {},
                "min": { "type": "number" },
                "max": { "type": "number" },
                "pattern": { "type": "string" },
                "enum": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          },
          "outputs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["output_id", "schema", "label", "is_primary"],
              "properties": {
                "output_id": { "type": "string", "minLength": 1 },
                "schema": {
                  "type": "string",
                  "enum": ["ohlc", "line", "event", "band", "histogram", "forecast"]
                },
                "label": { "type": "string", "minLength": 1 },
                "is_primary": { "type": "boolean" },
                "description": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        }
      },
      "default": []
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "agent_type": { "const": "indicator" }
        }
      },
      "then": {
        "required": ["indicators"]
      }
    }
  ],
  "additionalProperties": false
}
