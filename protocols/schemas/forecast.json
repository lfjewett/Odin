{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "acp/schemas/forecast.json",
  "title": "ACP Forecast Record",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "ts", "horizon_s", "value"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "seq": { "type": "integer", "minimum": 0 },
    "ts": { "type": "string", "format": "date-time" },
    "horizon_s": { "type": "integer", "minimum": 1 },
    "value": { "type": "number" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "upper": { "type": "number" },
    "lower": { "type": "number" },
    "metadata": {
      "type": "object",
      "description": "Agent-specific extension data not rendered on chart"
    }
  }
}
