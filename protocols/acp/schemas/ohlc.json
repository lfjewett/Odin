{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "acp/schemas/ohlc.json",
  "title": "ACP OHLC Record",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "ts", "open", "high", "low", "close", "volume", "rev", "bar_state"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "seq": { "type": "integer", "minimum": 0 },
    "rev": { "type": "integer", "minimum": 0 },
    "bar_state": { "type": "string", "enum": ["partial", "final"] },
    "ts": { "type": "string", "format": "date-time" },
    "open": { "type": "number" },
    "high": { "type": "number" },
    "low": { "type": "number" },
    "close": { "type": "number" },
    "volume": { "type": "number", "minimum": 0 }
  }
}
